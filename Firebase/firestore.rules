rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isUser() {
      return isAuth() && exists(/databases/$(database)/documents/Roles/$(request.auth.uid));
    }

    function isAdmin() {
      return isUser() && get(/databases/$(database)/documents/Roles/$(request.auth.uid)).data.role == "admin";
    }

    function isUserOwner(userId) {
      return isUser() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isUserOwner(userId) || isAdmin();
    }

    match /Roles/{userId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /Regions/{regionId} {
      allow get, list: if isUser() && (resource.data.enabled == true || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /Users/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /Regions/{regionId} {
        allow get, list: if isOwnerOrAdmin(userId);
        allow create, update, delete: if false;

        match /Instances/{instanceId} {
          allow get, list: if isOwnerOrAdmin(userId);
          allow create, update, delete: if false;
        }
      }
    }

    match /{path=**}/Instances/{instanceId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
