# Example values for a manual shared regional server deploy.
# Each region gets one long-lived server created from this stack.

availability_domain     = "xJLJ:US-SANJOSE-1-AD-1"
region                  = "us-sanjose-1"
compartment_id          = "ocid1.tenancy.oc1...replace_me"
subnet_id               = "ocid1.subnet.oc1.us-sanjose-1...replace_me"
source_image_id         = "ocid1.image.oc1.us-sanjose-1...replace_me"

# OCI requires ssh-rsa!
ssh_authorized_keys = [
    "ssh-rsa ... example",
    "ssh-rsa ... example"
]

instance_display_name   = "CloudLaunch"
vnic_display_name       = "CloudLaunch"
ipv6_subnet_cidr        = "2603:c024:c01a:8b69::/64"
shape                   = "VM.Standard.A1.Flex"
shape_memory_in_gbs     = 8
shape_ocpus             = 2
boot_volume_size_in_gbs = 50
boot_volume_vpus_per_gb = 10

region_id              = "us-sanjose-1"
api_hostname           = "us-sanjose-1.gateway.gocloudlaunch.com"
dashboard_cors_origin  = "https://gateway.gocloudlaunch.com"
fastapi_port           = 8000
caddy_acme_email       = "admin@example.com"
cloudflare_origin_pull_ca_path = "/etc/caddy/cloudflare-origin-pull-ca.pem"
cloudflare_origin_pull_ca_url  = "https://developers.cloudflare.com/ssl/static/authenticated_origin_pull_ca.pem"
caddy_version                  = "v2.8.4"
xcaddy_version                 = "latest"
caddy_rate_limit_module        = "github.com/mholt/caddy-ratelimit"
caddy_api_rate_limit_events    = 300
caddy_api_rate_limit_window    = "1m"

wg_interface                    = "wg0"
wg_listen_port                  = 51820
wg_address_v4                   = "10.0.0.1/24"
wg_address_v6                   = "fd42:42:42::1/64"
wg_network_v4                   = "10.0.0.0/24"
wg_network_v6                   = "fd42:42:42::/64"
wg_dns_address_v4               = "10.0.0.1"
wg_dns_address_v6               = "fd42:42:42::1"
wg_rate_limit                   = "25/second"
wg_rate_limit_burst             = 100
wg_server_private_key           = "..._WITH_SERVER_PRIVATE_KEY"
wg_endpoint_ipv4                = "1.2.3.4"

# Firebase Admin credential written to the host for the regional API.
# Leave firebase_credentials_json empty to copy the file manually instead.
firebase_credentials_file       = "/etc/cloudlaunch/firebase-credentials.json"
firebase_credentials_json       = ""

# Create your password with 'openssl passwd -6'
hashed_password = "$6$replace_with_real_salt$replace_with_real_hash_value"
