# Shared regional WireGuard server tfvars for one region.
# Copy terraform.tfvars.example to <region-id>.terraform.tfvars and fill in real values.
# Deploy with ./terraform.sh <region-id>. Real per-region tfvars are gitignored.

# --- OCI placement ---
availability_domain     = "AAAA:US-REGION-1-AD-1"
region                  = "us-region-1"
# OCI API-key profile in ~/.oci/config for this region's tenancy.
oci_config_profile      = "your-oci-profile"
compartment_id          = "ocid1.tenancy.oc1..replace_me"
subnet_id               = "ocid1.subnet.oc1.us-region-1.replace_me"
source_image_id         = "ocid1.image.oc1.us-region-1.replace_me"
ipv6_subnet_cidr        = "2603:xxxx:xxxx:xxxx:0000:0000:0000:0000/64"

# OCI requires ssh-rsa!
ssh_authorized_keys = [
    "ssh-rsa AAAA...replace_me user@host",
    "ssh-rsa AAAA...replace_me user@host"
]

# --- Instance shape ---
instance_display_name   = "CloudGateway-Region"
vnic_display_name       = "CloudGateway"
shape                   = "VM.Standard.A1.Flex"
shape_memory_in_gbs     = 12
shape_ocpus             = 2
boot_volume_size_in_gbs = 50
boot_volume_vpus_per_gb = 10

# --- Deploy ref (host fetches bootstrap + API from GitHub at boot) ---
# REQUIRED: push this tag to GitHub before `terraform apply` (it must exist on the
# remote). See docs/github-deployment-setup.md.
source_repo = "Albro3459/CloudGateway"
source_ref  = "deploy-v1.0.0"

# --- Regional API / dashboard ---
region_id              = "us-region-1"
api_hostname           = "us-region-1.gocloudlaunch.com"
dashboard_cors_origin  = "https://gocloudlaunch.com"
fastapi_port           = 8000
caddy_acme_email       = "admin@example.com"

# Grey-cloud (non-proxied) A record pointing at the server public IPv4.
wg_endpoint_hostname   = "wg.us-region-1.gocloudlaunch.com"

# --- Caddy / Cloudflare ---
cloudflare_origin_pull_ca_path = "/etc/caddy/cloudflare-origin-pull-ca.pem"
cloudflare_origin_pull_ca_url  = "https://developers.cloudflare.com/ssl/static/authenticated_origin_pull_ca.pem"
caddy_version                  = "v2.8.4"
xcaddy_version                 = "latest"
caddy_rate_limit_module        = "github.com/mholt/caddy-ratelimit"
caddy_api_rate_limit_events    = 300
caddy_api_rate_limit_window    = "1m"

# --- WireGuard interface / NAT ---
wg_interface                    = "wg0"
wg_listen_port                  = 51820
wg_address_v4                   = "10.0.0.1/24"
wg_address_v6                   = "fd42:42:42::1/64"
wg_network_v4                   = "10.0.0.0/24"
wg_network_v6                   = "fd42:42:42::/64"
wg_dns_address_v4               = "10.0.0.1"
wg_dns_address_v6               = "fd42:42:42::1"
wg_rate_limit                   = "25/second"
wg_rate_limit_burst             = 100
adguard_home_version            = "v0.107.77"

# Server WireGuard private key. Derive the public key with `wg pubkey` and put it in
# the Firestore region doc wireguardPublicKey (see Firebase/Secrets/regions.json).
wg_server_private_key           = "REPLACE_WITH_WG_SERVER_PRIVATE_KEY"

# --- Firebase Admin credential written to the host for the regional API ---
firebase_credentials_file       = "/etc/cloudgateway/firebase-credentials.json"
firebase_credentials_json       = <<FIREBASE_JSON
{
  "type": "service_account",
  "project_id": "replace_me",
  "private_key_id": "replace_me",
  "private_key": "-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n",
  "client_email": "firebase-adminsdk-xxxxx@replace_me.iam.gserviceaccount.com",
  "client_id": "replace_me",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/replace_me",
  "universe_domain": "googleapis.com"
}
FIREBASE_JSON

# Create your password with 'openssl passwd -6'
hashed_password = "$6$replace_with_salt$replace_with_hash"

# --- Region metadata (Firestore self-registration via cloudgateway-register-region) ---
region_display_name      = "Region"
region_display_order     = 1
region_capacity_limit    = 20
region_user_client_limit = 3

# --- AWS SES deployment notification email ---
ses_region            = "us-west-1"
ses_sender            = "CloudGateway <noreply@gocloudlaunch.com>"
aws_access_key_id     = "REPLACE_WITH_AWS_ACCESS_KEY_ID"
aws_secret_access_key = "REPLACE_WITH_AWS_SECRET_ACCESS_KEY"

# --- Cloudflare DNS (Terraform-managed; token stays on this machine, never on the host) ---
cloudflare_zone_id   = "replace_me"
cloudflare_api_token = "REPLACE_WITH_CLOUDFLARE_DNS_EDIT_TOKEN"

# --- Cloudflare Origin CA cert + key Caddy serves on the origin TLS hop ---
origin_cert = <<ORIGIN_CERT
-----BEGIN CERTIFICATE-----
REPLACE_ME
-----END CERTIFICATE-----
ORIGIN_CERT
origin_key = <<ORIGIN_KEY
-----BEGIN PRIVATE KEY-----
REPLACE_ME
-----END PRIVATE KEY-----
ORIGIN_KEY
